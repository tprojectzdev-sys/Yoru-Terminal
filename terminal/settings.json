{
  "$schema": "https://aka.ms/terminal-profiles-schema",

  "defaultProfile": "{powershell-guid}",

  "copyOnSelect": false,
  "copyFormatting": false,
  "confirmCloseAllTabs": false,
  "theme": "dark",
  "showTabsInTitlebar": true,
  "useAcrylicInTabRow": true,
  "tabWidthMode": "equal",

  "profiles": {
    "defaults": {
      "colorScheme": "Yoru",
      "cursorShape": "bar",
      "cursorColor": "#C0392B",

      "font": {
        "face": "0xProto Nerd Font Mono",
        "size": 11
      },

      "opacity": 85,
      "padding": "8, 8, 8, 8",
      "scrollbarState": "hidden",
      "startingDirectory": "%USERPROFILE%",
      "suppressApplicationTitle": false,
      "tabColor": "#C0392B",
      "useAcrylic": true
    },

    "list": [
      {
        "guid": "{powershell-guid}",
        "name": "PowerShell 7",
        "commandline": "pwsh.exe -NoLogo"
      }
    ]
  },

  "schemes": [
    {
      "name": "Yoru",

      "background": "#0D0D0D",
      "foreground": "#D4CFC9",

      "cursorColor": "#C0392B",
      "selectionBackground": "#3A1010",

      "black": "#1A1A1A",
      "red": "#C0392B",
      "green": "#4A6741",
      "yellow": "#B8960C",
      "blue": "#2C4A6E",
      "purple": "#5C2D5C",
      "cyan": "#2A5C5C",
      "white": "#C8C4BE",

      "brightBlack": "#3A3A3A",
      "brightRed": "#E74C3C",
      "brightGreen": "#6B8F5E",
      "brightYellow": "#D4AC0D",
      "brightBlue": "#3D6B9E",
      "brightPurple": "#7A3D7A",
      "brightCyan": "#3D7A7A",
      "brightWhite": "#E8E4DE"
    }
  ]
}
